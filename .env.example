# =====================================================================
# Sudut Ruang Dashboard — Environment Variables
# Copy file ini ke `.env` di root project, lalu sesuaikan nilainya.
# =====================================================================

# ---------------------------------------------------------------------
# n8n Webhook Base URL
# ---------------------------------------------------------------------
# Ini base URL untuk semua webhook n8n (tanpa trailing slash).
# Nilai ini juga bisa di-override dari halaman Settings dashboard
# (tersimpan di Supabase tabel `ai_config` key=`webhook_url`).
#
# Endpoint yang di-call dashboard:
#   POST {VITE_N8N_WEBHOOK_URL}/dashboard-message       → WF0 kirim pesan ke client
#   POST {VITE_N8N_WEBHOOK_URL}/toggle-mode             → toggle AI/Manual
#   POST {VITE_N8N_WEBHOOK_URL}/wa-estimator            → trigger WF2 estimator
#   POST {VITE_N8N_WEBHOOK_URL}/wa-proposal             → trigger WF3 proposal
#   POST {VITE_N8N_WEBHOOK_URL}/incoming-conversation   → WF4 sync hub
#   GET  {VITE_N8N_WEBHOOK_URL}/ping                    → health-check
# ---------------------------------------------------------------------
VITE_N8N_WEBHOOK_URL=https://n8n.srv1696073.hstgr.cloud/webhook

# Untuk development lokal (n8n di laptop):
# VITE_N8N_WEBHOOK_URL=http://localhost:5678/webhook

# ---------------------------------------------------------------------
# Mode developer
# ---------------------------------------------------------------------
# Set 'true' kalau mau pakai mock data — biasanya 'false' karena dashboard
# sudah pakai data real dari Supabase.
VITE_USE_MOCK_DATA=false

# ---------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------
# URL project + ANON key (public client key — JANGAN pakai service_role key di sini).
# Kalau dikosongkan, app akan fallback ke default project bawaan.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ---------------------------------------------------------------------
# Dashboard login (operator gate)
# ---------------------------------------------------------------------
# Kredensial untuk masuk ke dashboard. Kalau dikosongkan, default dipakai:
#   email: admin@sudutruang.com   password: sudutruang
# Catatan: ini gate sederhana (single operator). Untuk multi-user gunakan Supabase Auth.
VITE_DASHBOARD_EMAIL=admin@sudutruang.com
VITE_DASHBOARD_PASSWORD=sudutruang

# ---------------------------------------------------------------------
# (Opsional) WebSocket untuk realtime updates di masa depan
# ---------------------------------------------------------------------
# VITE_WEBSOCKET_URL=wss://your-realtime-server.com
