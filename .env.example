# n8n Webhook Configuration
# Copy this file to .env and update with your n8n webhook URLs

# Base URL for your n8n instance
VITE_N8N_WEBHOOK_URL=http://localhost:5678/webhook

# Alternative: Production n8n URL
# VITE_N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook

# Optional: Enable mock data for development
VITE_USE_MOCK_DATA=true

# Optional: WebSocket URL for real-time updates (future enhancement)
# VITE_WEBSOCKET_URL=ws://localhost:3001
