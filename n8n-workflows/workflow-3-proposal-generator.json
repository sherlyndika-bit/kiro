            "building_type": "={{ $json.buildingType }}",
            "tier": "={{ $json.tier }}",
            "area_sqm": "={{ $json.area }}",
            "rab_avg": "={{ $json.rabAvg }}",
            "fee_avg": "={{ $json.feeAvg }}",
            "total_fee": "={{ $json.totalFee }}",
