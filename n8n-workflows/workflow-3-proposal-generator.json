        "url": "https://n8n.srv1696073.hstgr.cloud/webhook/incoming-conversation",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"conversationId\": \"{{ $json.from }}\",\n  \"clientName\": {{ JSON.stringify($json.clientName) }},\n  \"source\": \"whatsapp\",\n  \"lastMessage\": \"Proposal {{ $json.proposalNo }} telah dikirim\",\n  \"mode\": \"ai\",\n  \"intent\": \"PROPOSAL_SENT\",\n  \"metadata\": {\n    \"proposalNo\": \"{{ $json.proposalNo }}\",\n    \"totalFee\": \"{{ $json.totalFeeFmt }}\",\n    \"validUntil\": \"{{ $json.validUntil }}\",\n    \"buildingType\": \"{{ $json.buildingType }}\"\n  },\n  \"timestamp\": \"{{ $now }}\"\n}",
